{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "type": "command", "bash": "bash \"$HOME/.copilot/hooks/session-start.sh\"", "timeoutSec": 30 }
    ],
    "userPromptSubmitted": [
      { "type": "command", "bash": "bash \"$HOME/.copilot/hooks/user-prompt-submit.sh\"", "timeoutSec": 5 },
      { "type": "command", "bash": "bash \"$HOME/.copilot/hooks/user-prompt-submit-context.sh\"", "timeoutSec": 10 }
    ],
    "preToolUse": [
      { "type": "command", "bash": "bash \"$HOME/.copilot/hooks/pre-tool-use.sh\"", "timeoutSec": 10 }
    ],
    "postToolUse": [
      { "type": "command", "bash": "bash \"$HOME/.copilot/hooks/post-tool-use.sh\"", "timeoutSec": 45 }
    ],
    "preCompact": [
      { "type": "command", "bash": "bash \"$HOME/.copilot/hooks/pre-compact.sh\"", "timeoutSec": 5 }
    ],
    "agentStop": [
      { "type": "command", "bash": "bash \"$HOME/.copilot/hooks/agent-stop.sh\"", "timeoutSec": 10 }
    ],
    "sessionEnd": [
      { "type": "command", "bash": "bash \"$HOME/.copilot/hooks/session-end-cleanup.sh\"", "timeoutSec": 150 },
      { "type": "command", "bash": "bash \"$HOME/.copilot/hooks/session-end-audit.sh\"", "timeoutSec": 30 }
    ]
  }
}
